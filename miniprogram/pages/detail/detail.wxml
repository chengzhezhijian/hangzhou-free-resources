<view class="page" wx:if="{{loading}}">
  <view class="loading-wrap">加载中…</view>
</view>

<view class="page" wx:elif="{{item}}">
  <view class="head">
    <text class="head__cat">{{item.catLabel}}</text>
    <text class="head__name">{{item.name}}</text>
    <text wx:if="{{item.dist}}" class="head__dist">距您约 {{item.dist}}</text>
  </view>

  <view class="block" wx:if="{{item.address}}">
    <text class="block__label">地址</text>
    <text class="block__value">{{item.address}}</text>
  </view>

  <view class="block" wx:if="{{item.hours}}">
    <text class="block__label">开放</text>
    <text class="block__value">{{item.hours}}</text>
  </view>

  <view class="block" wx:if="{{item.note}}">
    <text class="block__label">说明</text>
    <text class="block__value">{{item.note}}</text>
  </view>

  <view class="block" wx:if="{{item.tags.length}}">
    <text class="block__label">设施</text>
    <view class="tags">
      <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
  </view>

  <view class="block">
    <text class="block__label">所属</text>
    <text class="block__value">{{item.cityMeta}}</text>
  </view>

  <view class="actions safe-bottom">
    <button class="btn-primary action" bindtap="onNavigate">地图导航</button>
    <button class="btn-secondary action" bindtap="onCopy">复制地址</button>
  </view>
</view>
